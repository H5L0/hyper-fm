{
  "name": "electron-template",
  "version": "0.1.0",
  "description": "Minimal Electron + React + Vite template with TypeScript and a logger module.",
  "keywords": [
    "electron",
    "react",
    "vite",
    "typescript",
    "template"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build:node": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build --config vite.config.ts",
    "build": "npm run build:node && npm run build:renderer",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "dev:renderer": "vite --host 127.0.0.1 --config vite.config.ts",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev": "npm run build:node && concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "@vitest/coverage-v8": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "jsdom": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest",
    "wait-on": "latest"
  }
}
