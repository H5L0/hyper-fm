{
  "name": "hyper-fm",
  "version": "0.1.0",
  "description": "Desktop project folder manager for organizing, scanning, and syncing local projects.",
  "keywords": [
    "electron",
    "react",
    "vite",
    "typescript",
    "project-manager",
    "desktop-app",
    "sync"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build:node": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build --config vite.config.ts",
    "build": "npm run build:node && npm run build:renderer",
    "release:win": "npm run build && electron-builder --win portable -c.electronDist=node_modules/electron/dist",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "dev:renderer": "vite --host 127.0.0.1 --config vite.config.ts",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev": "npm run build:node && concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@rolldown/binding-win32-x64-msvc": "^1.0.0-rc.18",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "@vitest/coverage-v8": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "^26.8.1",
    "jsdom": "latest",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "lucide-react": "^1.11.0",
    "react": "latest",
    "react-dom": "latest",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tsx": "latest",
    "tw-animate-css": "^1.4.0",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.hyper-fm.app",
    "productName": "hyper-fm",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": ".release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "!dist/**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "hyper-fm-${version}-windows-${arch}.${ext}"
    }
  }
}
